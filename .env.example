# App
APP_NAME=HunterViz
DEBUG=false

# Auth (change in production)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Data paths (relative to project root or absolute)
USER_STORE_PATH=data/users.json
SUBSCRIPTION_STORE_PATH=data/subscriptions.json

# Cloud Run URL (for static site "Sign in" / "Sign up" links when not same-origin)
CLOUD_RUN_URL=

# Dashboard URL (link from user landing page)
DASHBOARD_URL=https://dashboard.hunterviz.com

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

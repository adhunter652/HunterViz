# App
APP_NAME=HunterViz
DEBUG=false
# PORT=8000   # Use 8080 (or another free port) if you get WinError 10013 on Windows

# Auth (change in production)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Data paths (relative to project root or absolute)
USER_STORE_PATH=data/users.json
SUBSCRIPTION_STORE_PATH=data/subscriptions.json

# GCS bucket for data sync (optional). When set, JSON files are synced to the bucket as the source of truth.
# GCS_DATA_BUCKET=hunterviz-data

# App server URL (used for redirects and cookie Secure flag). Production: https://app.hunterviz.com
# For local dev over HTTP, set CLOUD_RUN_URL=http://localhost:8000 so auth cookies work without HTTPS.
CLOUD_RUN_URL=https://app.hunterviz.com

# CORS allowed origins (comma-separated). Never use * when using cookies. Add your app/marketing domains.
# CORS_ORIGINS=https://app.hunterviz.com,https://hunterviz.com

# Dashboard URL (link from user landing page)
DASHBOARD_URL=https://dashboard.example.com

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
